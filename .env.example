# Copy this file to .env and fill in your values
# These come from the Azure portal under your MCC cache node registration

# Your Azure customer/tenant ID
CUSTOMER_ID=your-customer-id-here

# Unique ID for this cache node (from Azure portal)
CACHE_NODE_ID=your-cache-node-id-here

# Secret key for this cache node (from Azure portal)
CUSTOMER_KEY=your-customer-key-here

# How much disk space to allocate for caching (GB)
CACHE_DRIVE_SIZE_IN_GB=100

# Log verbosity: info | debug | error
LOG_LEVEL=info
