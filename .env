# Copy this file to .env and fill in your values
# All values come from the Azure portal under your MCC cache node registration

# Your Azure customer/tenant ID
CUSTOMER_ID=your-customer-id-here

# Unique ID for this cache node (from Azure portal)
CACHE_NODE_ID=your-cache-node-id-here

# Secret key for this cache node (from Azure portal)
CUSTOMER_KEY=your-customer-key-here

# One-time registration key — get a fresh one by copying the install command
# from the Azure portal. It expires after use, so generate a new one each deploy.
REGISTRATION_KEY=your-registration-key-here
